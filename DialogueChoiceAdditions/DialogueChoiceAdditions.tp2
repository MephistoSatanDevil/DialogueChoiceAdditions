BACKUP ~weidu_external/backup/DialogueChoiceAdditions~
// SUPPORT ~https://github.com/VioletSister/DialogueChoiceAdditions/issues~ // URL displayed if install fails
AUTHOR ~VioletSister~
VERSION ~1.0.1~
LANGUAGE ~English~ ~en_US~ ~DialogueChoiceAdditions/installer/translation/en_US/setup.tra~

BEGIN @0  // Dialogue Choice Additions: Core
LABEL ~DialogueChoiceAdditions-Core~
/* StringRefs */
OUTER_SET stringref_fitting_last_words = 10844
OUTER_SET stringref_no_words = 37478
OUTER_SET stringref_where_does_the_maze_lead = 11727
OUTER_SET stringref_where_does_it_lead = 10843
OUTER_SET stringref_tandem_in_extremis_evidently = 27505
OUTER_SET stringref_blast_you_all = 10833
OUTER_SET stringref_were_not_here_to_torture = 1020
OUTER_SET stringref_who_are_you_master_gnome = 51767
OUTER_SET stringref_this_isnt_the_surface = 51768
OUTER_SET stringref_you_have_thirty_seconds = 51769
OUTER_SET stringref_farewell_know_that_you_have_a_friend = 41416
OUTER_SET stringref_no_dont_dont_dont = 64259
OUTER_SET stringref_it_is_not_a_very_noble_act_to_kill = 64260
OUTER_SET stringref_no_dont_do_that_please_just_let_us_go = 64269
OUTER_SET stringref_but_it_is_a_sensible_act = 64261
OUTER_SET stringref_free_us_please_ill_do_anything = 64262
OUTER_SET stringref_the_missing_patrol = 64446
OUTER_SET stringref_the_missing_patrol_my_next_task = 64444
OUTER_SET stringref_the_missing_patrol_i_must_find = 64440
OUTER_SET stringref_she_thought_i_was_powerless = 64167
OUTER_SET stringref_what_forgotten_god = 64078
OUTER_SET stringref_i_am_here_to_free_you_i_found_the_key = 64079
OUTER_SET stringref_i_will_return_once_i_have_the_means = 64081
OUTER_SET stringref_rot_in_your_cell = 64082
OUTER_SET stringref_ive_come_here_looking_for_a_wardstone = 64062
ACTION_IF GAME_IS ~eet~ BEGIN
    OUTER_SET EET_OFFSET = 200000
    OUTER_SET stringref_fitting_last_words = stringref_fitting_last_words + EET_OFFSET
    OUTER_SET stringref_no_words = stringref_no_words + EET_OFFSET
    OUTER_SET stringref_where_does_the_maze_lead = stringref_where_does_the_maze_lead + EET_OFFSET
    OUTER_SET stringref_where_does_it_lead = stringref_where_does_it_lead + EET_OFFSET
    OUTER_SET stringref_tandem_in_extremis_evidently = stringref_tandem_in_extremis_evidently + EET_OFFSET
    OUTER_SET stringref_blast_you_all = stringref_blast_you_all + EET_OFFSET
    OUTER_SET stringref_were_not_here_to_torture = stringref_were_not_here_to_torture + EET_OFFSET
    OUTER_SET stringref_who_are_you_master_gnome = stringref_who_are_you_master_gnome + EET_OFFSET
    OUTER_SET stringref_this_isnt_the_surface = stringref_this_isnt_the_surface + EET_OFFSET
    OUTER_SET stringref_you_have_thirty_seconds = stringref_you_have_thirty_seconds + EET_OFFSET
    OUTER_SET stringref_farewell_know_that_you_have_a_friend = stringref_farewell_know_that_you_have_a_friend + EET_OFFSET
    OUTER_SET stringref_no_dont_dont_dont = stringref_no_dont_dont_dont + EET_OFFSET
    OUTER_SET stringref_no_dont_do_that_please_just_let_us_go = stringref_no_dont_do_that_please_just_let_us_go + EET_OFFSET
    OUTER_SET stringref_it_is_not_a_very_noble_act_to_kill = stringref_it_is_not_a_very_noble_act_to_kill + EET_OFFSET
    OUTER_SET stringref_but_it_is_a_sensible_act = stringref_but_it_is_a_sensible_act + EET_OFFSET
    OUTER_SET stringref_free_us_please_ill_do_anything = stringref_free_us_please_ill_do_anything + EET_OFFSET
    OUTER_SET stringref_the_missing_patrol = stringref_the_missing_patrol + EET_OFFSET
    OUTER_SET stringref_the_missing_patrol_my_next_task = stringref_the_missing_patrol_my_next_task + EET_OFFSET
    OUTER_SET stringref_the_missing_patrol_i_must_find = stringref_the_missing_patrol_i_must_find + EET_OFFSET
    OUTER_SET stringref_she_thought_i_was_powerless = stringref_she_thought_i_was_powerless + EET_OFFSET
    OUTER_SET stringref_what_forgotten_god = stringref_what_forgotten_god + EET_OFFSET
    OUTER_SET stringref_i_am_here_to_free_you_i_found_the_key = stringref_i_am_here_to_free_you_i_found_the_key + EET_OFFSET
    OUTER_SET stringref_i_will_return_once_i_have_the_means = stringref_i_will_return_once_i_have_the_means + EET_OFFSET
    OUTER_SET stringref_rot_in_your_cell = stringref_rot_in_your_cell + EET_OFFSET
    OUTER_SET stringref_ive_come_here_looking_for_a_wardstone = stringref_ive_come_here_looking_for_a_wardstone + EET_OFFSET
END
// Baldur's Gate (base game) content
ACTION_IF GAME_IS ~eet bgee~ BEGIN
    /* Journal */
    WITH_TRA ~%MOD_FOLDER%/installer/translation/%LANGUAGE%/dca_dialogue_edits_bg.tra~ BEGIN
        /* Dialogue */
        PRINT @90003  /* ~Compiling dialogue files for Baldur's Gate content ...~ */
        OUTER_SPRINT doppelganger_merchant_busy_response ~@8000~  /* ~[MERCHANT] Leave us alone, will you? Nothin' for you here.~ [MANCO02] */
        ACTION_IF MOD_IS_INSTALLED ~vveBG.tp2~ ~0~ BEGIN
            OUTER_SPRINT doppelganger_merchant_busy_response ~@8001~  /* ~[MERCHANT] Still you pester us! Do you have no shame?!~ [DCDPM01] */
        END
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_DIARMID.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_DOPMER.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_DOPPSM.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_FLAMGG.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_JHASSO.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_PROST4.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_RAGEFA.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_RAHVIN.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_RIELTA.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_SCAR.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_SILENC.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_TELANO.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/baldurs_gate/src/dialogue/dca_VOLETA.d~
        OUTER_SET JARLS_ADVENTURE_PACK_SEVEN_SUNS_ID = ID_OF_LABEL ~Setup-JA#BGT_AdvPack.tp2~ ~JA#BGT_AdvPack-Seven_Suns~
    END
END
// Baldur's Gate: Siege of Dragonspear content
ACTION_IF GAME_IS ~eet~ OR GAME_INCLUDES "sod" BEGIN
    WITH_TRA ~%MOD_FOLDER%/installer/translation/%LANGUAGE%/dca_dialogue_edits_sod.tra~ BEGIN
        /* Strings */
        PRINT @90009  /* ~Replacing strings for Siege of Dragonspear content ...~ */
        ACTION_IF GAME_IS ~eet~ BEGIN
            // Modify the journal entry for if the player killed Keherrem to phrase deception as optional
            // (useful if the player killed them for pragmatic reasons but doesn't want to lie)
            STRING_SET 264444 @7016  // The Missing Patrol - Killed
        END ELSE BEGIN
            // Journal entry for if the player killed Keherrem modified to phrase deception as optional
            // (useful if the player killed them for pragmatic reasons but doesn't want to lie)
            STRING_SET 64444 @7016  // The Missing Patrol - Killed
        END
        /* Journal */
        PRINT @90007  /* ~Adding journal entries for Siege of Dragonspear content ...~ */
        ACTION_IF GAME_IS ~eet~ BEGIN
            ADD_JOURNAL EXISTING MANAGED TITLE (#264446) @7011  // The Missing Patrol - leave be
            ADD_JOURNAL EXISTING MANAGED TITLE (#264446) @7012  // The Missing Patrol - leave be killed anyway
            ADD_JOURNAL EXISTING MANAGED TITLE (#264446) @7017  // The Missing Patrol - kill or free said to leave anyway
            ADD_JOURNAL EXISTING MANAGED TITLE (#264982) @8003  // The Eyeless Priestess - leave be
            ADD_JOURNAL EXISTING MANAGED TITLE (#264982) @8004  // The Eyeless Priestess - free - good
            ADD_JOURNAL EXISTING MANAGED TITLE (#264982) @8005  // The Eyeless Priestess - free - neutral/evil
        END ELSE BEGIN
            ADD_JOURNAL EXISTING MANAGED TITLE (#64446) @7011  // The Missing Patrol leave be
            ADD_JOURNAL EXISTING MANAGED TITLE (#64446) @7012  // The Missing Patrol leave be killed anyway
            ADD_JOURNAL EXISTING MANAGED TITLE (#64446) @7017  // The Missing Patrol kill or free said to leave anyway
            ADD_JOURNAL EXISTING MANAGED TITLE (#64982) @8003  // The Eyeless Priestess - leave be
            ADD_JOURNAL EXISTING MANAGED TITLE (#64982) @8004  // The Eyeless Priestess - free - good
            ADD_JOURNAL EXISTING MANAGED TITLE (#64982) @8005  // The Eyeless Priestess - free - neutral/evil
        END
        /* Script */
        PRINT @90008  /* ~Extending scripts for Siege of Dragonspear content ...~ */
        // Add "I decided to kill the crusaders anyway." to quest journal
        // if the player decides to do that despite explicitly saying they won't
        // Note that Keherrem's name uses a different spelling in variable names
        COPY_EXISTING ~BDLEVER2.BCS~ ~override~
            DECOMPILE_AND_PATCH BEGIN
                REPLACE_TEXTUALLY EXACT_MATCH
~IF
  Clicked([ANYONE])
  Global("bd_sdd201_missing_keherram_lever","GLOBAL",1)
  !Global("bd_sdd201_missing_keherram","GLOBAL",3)
  !Global("bd_sdd201_missing_door","GLOBAL",2)
  !GlobalTimerNotExpired("BD_BARK","MYAREA")
  GlobalLT("bd_plot","global",250)
THEN
  RESPONSE #100
    AddJournalEntry(%stringref_the_missing_patrol_my_next_task%,QUEST)
    Continue()
END~
~IF
  Clicked([ANYONE])
  Global("bd_sdd201_missing_keherram_lever","GLOBAL",1)
  Global("bd_sdd201_missing_keherram","GLOBAL",100)
  !Global("bd_sdd201_missing_door","GLOBAL",2)
  !GlobalTimerNotExpired("BD_BARK","MYAREA")
  GlobalLT("bd_plot","global",250)
THEN
  RESPONSE #100
    AddJournalEntry(@7012,QUEST)  // The Missing Patrol I can take the crusader leader's badge back to the crusader camp and lie about what happened. I had meant neither to rescue nor kill them, but a nearby lever proved too tempting. When I pulled it, spikes shot up through the cages and impaled the crusaders, killing all three of them.
    // ka = kill anyway
    SetGlobal("bd_sdd201_missing_keherram_ka","GLOBAL",1)  // Player killed the crusaders by pulling the lever after explicitly deciding to leave them alive
    Continue()
END
IF
  Clicked([ANYONE])
  Global("bd_sdd201_missing_keherram_lever","GLOBAL",1)
  !Global("bd_sdd201_missing_keherram","GLOBAL",100)
  !Global("bd_sdd201_missing_keherram","GLOBAL",3)
  !Global("bd_sdd201_missing_door","GLOBAL",2)
  !GlobalTimerNotExpired("BD_BARK","MYAREA")
  GlobalLT("bd_plot","global",250)
THEN
  RESPONSE #100
    AddJournalEntry(%stringref_the_missing_patrol_my_next_task%,QUEST)
    Continue()
END~
            END
        // When the last chance to save or kill Keherrem has passed,
        // mark the "The Missing Patrol" as completed if the player explicitly decided to leave him alive
        EXTEND_TOP ~BD2000.bcs~ ~%MOD_FOLDER%/core/siege_of_dragonspear/src/script/dca_BD2000.baf~ EVALUATE_BUFFER
        /* Dialogue */
        PRINT @90004  /* ~Compiling dialogue files for Siege of Dragonspear content ...~ */
        // They get their own line in vanilla, and our line is for everyone else
        OUTER_SPRINT compromise_dialogue_changes ~~~~~
            IF ~ OR(2)
                !Class(Player1,CLERIC_ALL)
                !Alignment(Player1,LAWFUL_GOOD)
                OR(2)
                !Class(Player1,CLERIC_ALL)
                !Alignment(Player1,LAWFUL_NEUTRAL)
                OR(2)
                !Class(Player1,PALADIN_ALL)
                !Alignment(Player1,LAWFUL_GOOD)
                OR(2)
                !Class(Player1,PALADIN_ALL)
                !Alignment(Player1,LAWFUL_NEUTRAL)
                ~ THEN REPLY @7 /* ~I appreciate the distinction, but my answer is no.~ */ DO ~SetGlobal("bd_MDD1001_morale","global",1)
        ~ GOTO 25
        ~~~~~
        OUTER_SPRINT impale_or_not_rasaad_dorn_choices ~~~~~
            IF ~~ THEN REPLY @7003 /* ~I am merely considering all options. Now, how might we free them?~ */ EXTERN ~BDKHARMY~ 3
            IF ~~ THEN REPLY @7004 /* ~I will not take the lives of helpless prisoners. But neither will I open the door for crusaders. The cage stays shut.~ */ EXTERN ~BDKHARMY~ LetKharmyBe
            IF ~~ THEN REPLY @7005 /* ~Letting crusaders live is a risk I am not willing to take. I will kill them.~ */ EXTERN ~BDKHARMY~ DecidedToKillKharmyNew
            IF ~~ THEN REPLY @7006 /* ~Stand aside. I want to see what the spikes do.~ */ EXTERN ~BDKHARMY~ DecidedToKillKharmyNew
            IF ~~ THEN REPLY @7010 /* ~I will have to think about this.~ */ EXTERN ~BDKHARMY~ ThinkAboutIt
        ~~~~~
        // Disable overlapping dialogue options from the mod "Jastey's Tweaks for SoD and EET (and BGT)", component "More Dialogue Choices _Prevent Dead Ends"
        OUTER_SET JATSEYS_TWEAKS_MORE_DIALOGUE_CHOICES_PREVENT_DEAD_ENDS_ID = ID_OF_LABEL ~setup-c#sodtweaks.tp2~ ~JasteySodTweaks-MoreDialogueChoices_PreventDeadEnds~
        ACTION_IF MOD_IS_INSTALLED ~setup-c#sodtweaks.tp2~ ~%JATSEYS_TWEAKS_MORE_DIALOGUE_CHOICES_PREVENT_DEAD_ENDS_ID%~ BEGIN
            PRINT @90010  /* ~Compiling dialogue files for the "More Dialogue Choices _Prevent Dead Ends" component of Jastey's Tweaks for SoD and EET (and BGT) ...~ */
            COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/jasteys_tweaks_compatibility_patch/siege_of_dragonspear/src/dialogue/dca_jt_BDNEDERL.d~
            COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/jasteys_tweaks_compatibility_patch/siege_of_dragonspear/src/dialogue/dca_jt_BDDELANC.d~
        END
        PRINT @90012  /* ~Compiling dialogue files for vanilla Siege of Dragonspear content ...~ */
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDARBING.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDBELLOW.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDDELANC.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDDYINGM.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDKHARMY.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDMADELE.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDMURS.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDNEDERL.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDPWATER.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDSHAPUR.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDSLUG.d~
        COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/core/siege_of_dragonspear/src/dialogue/dca_BDTHERLI.d~
    END
    /* Sound */
    PRINT @90006  /* ~Installing voiceover files for Siege of Dragonspear content ...~ */
    COPY ~%MOD_FOLDER%/core/siege_of_dragonspear/res/audio/voiceover/%LANGUAGE%~ ~lang/%LANGUAGE%/sounds~
END

BEGIN @1  // VVE Compatibility Patch
LABEL ~DialogueChoiceAdditions-VVECompatibilityPatch~
// VVE is not technically required, but we add this line to prevent users from accidentally installing this component but not Voices Voices Extravaganza as that would be undesirable to any sane person
ACTION_IF (NOT MOD_IS_INSTALLED ~vveBG.tp2~ ~0~) AND (NOT MOD_IS_INSTALLED ~vveSOD.tp2~ ~0~) BEGIN
    FAIL @90000
END
// Baldur's Gate (base game) content
ACTION_IF MOD_IS_INSTALLED ~vveBG.tp2~ ~0~ BEGIN
    ACTION_IF GAME_IS ~eet bgee~ BEGIN
        PRINT @90001  /* ~Installing voiceover files for Baldur's Gate content for use with VVE ...~ */
        COPY ~%MOD_FOLDER%/compatibility_patch_vve/baldurs_gate/res/audio/voiceover/%LANGUAGE%~ ~lang/%LANGUAGE%/sounds~
    END
END
// Baldur's Gate: Siege of Dragonspear content
ACTION_IF MOD_IS_INSTALLED ~vveSOD.tp2~ ~0~ BEGIN
    ACTION_IF GAME_IS ~eet~ OR GAME_INCLUDES "sod" BEGIN
        PRINT @90002  /* ~Installing voiceover files for Siege of Dragonspear content for use with VVE ...~ */
        COPY
            ~%MOD_FOLDER%/compatibility_patch_vve/siege_of_dragonspear/res/audio/voiceover/%LANGUAGE%~ ~lang/%LANGUAGE%/sounds~
    END
END
