    OUTER_SET stringref_no_dont_do_that_please_just_let_us_go = stringref_no_dont_do_that_please_just_let_us_go + EET_OFFSET
    OUTER_SET stringref_it_is_not_a_very_noble_act_to_kill = stringref_it_is_not_a_very_noble_act_to_kill + EET_OFFSET
    OUTER_SET stringref_but_it_is_a_sensible_act = stringref_but_it_is_a_sensible_act + EET_OFFSET
